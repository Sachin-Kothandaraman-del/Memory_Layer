# ============================================================================
# Echo / memlayer environment variables
# Copy this file to `.env` and fill in your values.
# `.env` is git-ignored and auto-loaded by the local apps — never commit it.
# For the Vercel deployment, set the same variables in:
#   Vercel dashboard -> your project -> Settings -> Environment Variables
# ============================================================================

# ---------------------------------------------------------------- Gemini API
# Required everywhere (local + cloud).
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ------------------------------------------------------------------ Supabase
# Required only for the cloud deployment (accounts + Postgres storage).
# Find all three in: Supabase dashboard -> Project Settings -> API
#
# "Project URL" (looks like https://abcdefghij.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co
#
# "anon public" key (safe to expose to browsers)
SUPABASE_ANON_KEY=your-anon-public-key-here
#
# "service_role" key  -- SECRET: full database access, server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------- Optional (cloud hardening)
# Vercel-only: protects the weekly-reflection cron endpoint (any long random
# string; Vercel sends it automatically with cron requests).
# CRON_SECRET=generate-a-long-random-string
# Per-user hourly cap on journal entries (protects your Gemini quota).
# ECHO_ENTRY_LIMIT_PER_HOUR=30

# ---------------------------------------------------- Optional local overrides
# Defaults shown; uncomment to change.
# MEMLAYER_DB_PATH=memlayer.db          # db file for the memlayer CLI/dashboard
# ECHO_DB_PATH=echo.db                  # db file for the local echo-journal app
# MEMLAYER_LLM_MODEL=gemini-2.5-flash
# MEMLAYER_EMBED_MODEL=gemini-embedding-001
